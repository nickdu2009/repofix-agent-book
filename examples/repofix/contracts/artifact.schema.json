{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repofix.dev/schemas/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "run_id", "kind", "content_type", "size_bytes", "sha256", "created_at"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "enum": ["patch", "test_report", "log", "trace"]},
    "content_type": {"type": "string", "minLength": 1},
    "size_bytes": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "download_url": {"type": ["string", "null"], "format": "uri"},
    "summary": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
