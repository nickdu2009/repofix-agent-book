{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repofix.dev/schemas/run-event.schema.json",
  "title": "RunEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "run_id", "sequence", "type", "occurred_at", "schema_version", "data"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "type": {
      "type": "string",
      "enum": [
        "run.started",
        "sandbox.created",
        "sandbox.deleted",
        "sandbox.cleanup_failed",
        "step.started",
        "tool.started",
        "tool.completed",
        "tests.completed",
        "patch.created",
        "run.succeeded",
        "run.failed",
        "run.cancelled",
        "run.timed_out"
      ]
    },
    "occurred_at": {"type": "string", "format": "date-time"},
    "schema_version": {"const": 1},
    "data": {"type": "object"}
  }
}
