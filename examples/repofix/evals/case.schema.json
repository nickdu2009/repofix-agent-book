{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repofix.dev/schemas/eval-case.schema.json",
  "title": "EvalCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "language",
    "test_target",
    "timeout_seconds",
    "forbidden_paths"
  ],
  "properties": {
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "language": {"enum": ["python", "go", "typescript"]},
    "test_target": {"enum": ["unit"]},
    "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 900},
    "forbidden_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
